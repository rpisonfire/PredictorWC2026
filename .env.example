# Postgres connection string (Neon, Supabase, Vercel Postgres, etc.)
# Lokalnie: connection string z Twojego Neon dev branch
# Produkcja (Vercel): ustaw to samo w Environment Variables
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Optional: football API key for fetching teams/players from api-football.com
FOOTBALL_API_KEY=""

# Optional: football-data.org token (darmowy, ma WC w free tier, bez zdjęć)
# Rejestracja: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=""

# Sekret do auto-sync (Vercel Cron). Wygeneruj losowy string:
#   openssl rand -hex 32
# Bez tego endpoint /api/cron/sync nie ma autoryzacji (na proda KONIECZNIE ustaw)
CRON_SECRET=""
